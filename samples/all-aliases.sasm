    output = wedo2.tilt(1)

  proc alias_sample_227():
    # alias wedo2.tilted/1
    output = wedo2.tilted(1)

  # alias wedo2.whentilted/1
  @wedo2.whentilted 1:
    control.stop "this script"
}
